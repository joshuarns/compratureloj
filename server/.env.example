# Credenciales del servidor proxy — nunca van al cliente ni al repositorio.
# Copia este archivo como .env y rellena los valores reales.

# URL base de WooCommerce REST API v3
WC_BASE_URL=https://compratureloj.com.mx/wp-json/wc/v3

# URL base de WordPress REST API v2
WP_BASE_URL=https://compratureloj.com.mx/wp-json/wp/v2

# Consumer Key y Secret de WooCommerce
WC_KEY=
WC_SECRET=

# Puerto en el que corre el proxy (default 3001)
PORT=3001
