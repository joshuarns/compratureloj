# Plantilla de variables de entorno del cliente React.
#
# Para desarrollo: cp .env.example .env.development
# Para producción: .env.production solo necesita REACT_APP_USE_PROXY=true
#                  Las credenciales reales van en server/.env (nunca en el cliente).
#
# Carga automática por CRA:
#   npm start      →  .env.development
#   npm run build  →  .env.production

# false = peticiones directas a WordPress (desarrollo local)
# true  = peticiones al proxy Express que guarda las credenciales (producción)
REACT_APP_USE_PROXY=false

# Solo necesarios cuando REACT_APP_USE_PROXY=false
REACT_APP_WC_BASE_URL=
REACT_APP_WP_BASE_URL=
REACT_APP_WC_KEY=
REACT_APP_WC_SECRET=
